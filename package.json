{
  "name": "prompt-coco-pilot",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test:node": "node --test qoder-ui/test/*.test.js codex-ui/test/*.test.js",
    "qoder:optimize-input": "node qoder-ui/bin/qoder-optimize-input.js",
    "qoder:install-agent": "node qoder-ui/bin/qoder-optimize-input.js install-agent qoder",
    "qoder:uninstall-agent": "node qoder-ui/bin/qoder-optimize-input.js uninstall-agent qoder",
    "codex:launch": "node codex-ui/bin/codex-optimize-input.js launch",
    "codex:probe": "node codex-ui/bin/codex-optimize-input.js probe",
    "codex:daemon": "node codex-ui/bin/codex-optimize-input.js",
    "codex:install-agent": "node codex-ui/bin/codex-optimize-input.js install-agent",
    "codex:uninstall-agent": "node codex-ui/bin/codex-optimize-input.js uninstall-agent",
    "claude:float": "python3 claude-ui/bin/claude-float.py",
    "claude:session": "python3 claude-ui/bin/claude-float.py session",
    "claude:ui": "/opt/homebrew/bin/python3.12 claude-ui/bin/claude-webview.py"
  }
}
